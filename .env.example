# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# LLM Provider: 'auto' | 'ollama' | 'openai' | 'simulate'
# auto = try Ollama first, then OpenAI, then simulated fallback
LLM_PROVIDER=auto

# Ollama (local LLM)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# OpenAI (cloud LLM)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: Analytics
NEXT_PUBLIC_GA_ID=

# Optional: Sentry
NEXT_PUBLIC_SENTRY_DSN=

