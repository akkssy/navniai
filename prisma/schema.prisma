// NavniAI - Prisma Schema
// User management, workflows, and settings

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Auth Models (NextAuth compatible) ───

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  workflows   Workflow[]
  llmSettings LLMSettings?
  customAgents CustomAgent[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App Models ───

model Workflow {
  id        String   @id @default(cuid())
  name      String
  status    String   @default("draft")
  config    String   @default("{}") // JSON string of workflow nodes/edges
  runs      Int      @default(0)
  lastRunAt DateTime?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflowRuns WorkflowRun[]
}

model WorkflowRun {
  id         String   @id @default(cuid())
  workflowId String
  status     String   @default("running")
  output     String?  // JSON string
  startedAt  DateTime @default(now())
  completedAt DateTime?

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
}

model LLMSettings {
  id             String @id @default(cuid())
  userId         String @unique
  activeProvider String @default("ollama")
  fallbackChain  String @default("ollama,groq,openai,openrouter") // comma-separated
  providersJson  String @default("{}") // JSON of provider configs

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CustomAgent {
  id           String @id @default(cuid())
  userId       String
  name         String
  type         String
  icon         String @default("🤖")
  systemPrompt String @default("")
  config       String @default("{}") // JSON
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
